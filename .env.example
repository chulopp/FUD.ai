DEEPSEEK_API_KEY=
# DeepSeek is called directly (not via OpenCode Go — had production timeouts).
DEEPSEEK_BASE_URL=https://api.deepseek.com

# --- ON-CHAIN & MARKET API ---
BYBIT_API_KEY=
BYBIT_API_SECRET=
# Bybit domain: api.bybit.com is blocked by Indonesian ISPs.
# Use api.bytick.com (production mainnet, same API, different CDN domain).
# For local dev / CI testnet: set to https://api-testnet.bytick.com
BYBIT_BASE_URL=https://api.bytick.com
GOPLUS_APP_KEY=
GOPLUS_APP_SECRET=
RUGCHECK_API_KEY=
DEXSCREENER_API_KEY=
DEFILLAMA_API_KEY=
COINGECKO_API_KEY=

# --- NATIVE SOCIAL SCRAPERS ---
# Twitter/X: via RapidAPI (not MCP XActions). Requires RAPIDAPI_KEY.
RAPIDAPI_KEY=
RAPIDAPI_HOST=twitter-api45.p.rapidapi.com
# Telegram: via public web scraping t.me/s/{channel} — no credentials needed.

# --- AMAZON BEDROCK ---
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
