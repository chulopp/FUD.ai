# --- NATIVE SOCIAL SCRAPERS ---
# Telegram requires NO credentials — uses public t.me/s/{channel} web preview.
# Twitter requires ONE of the two auth options below.
#   Option A (recommended, most reliable): interactive login creds.
TWITTER_USERNAME=
TWITTER_PASSWORD=
TWITTER_EMAIL=
#   Option B: cookies exported from a logged-in x.com browser session.
#             Both auth_token AND ct0 are required; auth_token alone returns 401.
TWITTER_AUTH_TOKEN=
TWITTER_CT0=
#   Option C: raw cookie header form, e.g. 'auth_token=xxx; ct0=yyy; twid=u%3Axxx'
TWITTER_COOKIES=